# Optional: enables NewsAPI source.
NEWSAPI_KEY=

# Optional: Reddit RSS now sometimes requires per-user feed params.
# These come from Reddit's RSS feed URLs if your account exposes them.
REDDIT_RSS_USER=
REDDIT_RSS_FEED=

# Optional: Ollama rater settings.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-coder:480b-cloud
OLLAMA_TEMPERATURE=0.3
OLLAMA_TIMEOUT=120

# Optional: app behavior.
ENABLED_SOURCES=ANTH,RDIT,RDSR,HN,GOOG,NEWS
REFRESH_RATE_CAP=10
REFRESH_ENRICH_CAP=20
REFRESH_DELAY_SECONDS=1.5
ENRICH_DELAY_SECONDS=2.0
AUTO_REFRESH_MINUTES=60
